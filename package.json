{
  "name": "hydra",
  "version": "1.2.0",
  "description": "Multi-agent AI orchestration system",
  "type": "module",
  "license": "MIT",
  "author": "Silly Pepper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrimeLocus/Hydra.git"
  },
  "homepage": "https://github.com/PrimeLocus/Hydra#readme",
  "bugs": {
    "url": "https://github.com/PrimeLocus/Hydra/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "hydra": "./bin/hydra-cli.ts",
    "hydra-client": "./lib/orchestrator-client.ts",
    "hydra-daemon": "./lib/orchestrator-daemon.ts"
  },
  "files": [
    "bin/",
    "lib/",
    "docs/*.md",
    "docs/research/*.md",
    "hydra.config.json",
    "recent-projects.json",
    "CLAUDE.md",
    "README.md"
  ],
  "scripts": {
    "start": "node lib/orchestrator-daemon.ts start",
    "stop": "node lib/orchestrator-client.ts stop",
    "status": "node lib/orchestrator-client.ts status",
    "summary": "node lib/orchestrator-client.ts summary",
    "stats": "node lib/orchestrator-client.ts stats",
    "usage": "node lib/hydra-usage.ts",
    "model": "node lib/orchestrator-client.ts model",
    "models": "node lib/hydra-models.ts",
    "models:select": "node lib/hydra-models-select.ts",
    "setup": "node lib/hydra-setup.ts setup",
    "init": "node lib/hydra-setup.ts init",
    "init:daemon": "node lib/orchestrator-client.ts init",
    "go": "node lib/hydra-operator.ts mode=auto",
    "council": "node lib/hydra-council.ts",
    "dispatch": "node lib/hydra-dispatch.ts",
    "nightly": "node lib/hydra-nightly.ts",
    "audit": "node lib/hydra-audit.ts",
    "actualize": "node lib/hydra-actualize.ts",
    "actualize:review": "node lib/hydra-actualize-review.ts review",
    "actualize:status": "node lib/hydra-actualize-review.ts status",
    "actualize:clean": "node lib/hydra-actualize-review.ts clean",
    "nightly:review": "node lib/hydra-nightly-review.ts review",
    "nightly:status": "node lib/hydra-nightly-review.ts status",
    "nightly:clean": "node lib/hydra-nightly-review.ts clean",
    "evolve": "node lib/hydra-evolve.ts",
    "evolve:review": "node lib/hydra-evolve-review.ts review",
    "evolve:status": "node lib/hydra-evolve-review.ts status",
    "evolve:clean": "node lib/hydra-evolve-review.ts clean",
    "evolve:knowledge": "node lib/hydra-evolve-review.ts knowledge",
    "evolve:suggestions": "node lib/hydra-evolve-suggestions-cli.ts",
    "tasks": "node lib/hydra-tasks.ts",
    "tasks:review": "node lib/hydra-tasks-review.ts review",
    "tasks:status": "node lib/hydra-tasks-review.ts status",
    "tasks:clean": "node lib/hydra-tasks-review.ts clean",
    "research:todo": "node scripts/gen-research-todo.ts",
    "eval": "node lib/hydra-eval.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:complexity": "node scripts/complexity-report.ts",
    "lint:mermaid": "node scripts/lint-mermaid.ts",
    "lint:cycles": "node scripts/detect-cycles.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "quality": "npm run lint && npm run format:check && npm run typecheck && npm run lint:cycles",
    "setup:hooks": "node scripts/setup-hooks.ts",
    "test": "node --test --experimental-test-module-mocks 'test/**/*.test.{ts,mjs}'",
    "test:coverage": "c8 npm test",
    "test:coverage:check": "node_modules/.bin/c8 check-coverage",
    "test:report": "node --test 'test/**/*.test.{ts,mjs}' --test-reporter=tap --test-reporter-destination=docs/coordination/test-results.tap",
    "package": "node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && npm pack --pack-destination dist",
    "package:dry-run": "npm pack --dry-run",
    "build:exe": "node scripts/build-exe.ts",
    "build:exe:ci": "node scripts/build-exe.ts --ci",
    "install:global": "npm install -g .",
    "uninstall:global": "npm uninstall -g hydra",
    "prepare": "husky",
    "test:mutation": "stryker run"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "node scripts/lint-mermaid.ts",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pkg": {
    "scripts": [
      "bin/**/*.cjs",
      "bin/**/*.ts",
      "lib/**/*.ts"
    ],
    "assets": [
      "bin/*.ps1",
      "docs/*.md",
      "docs/research/*.md",
      "hydra.config.json",
      "recent-projects.json",
      "CLAUDE.md",
      "README.md"
    ]
  },
  "devDependencies": {
    "@a24z/mermaid-parser": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/madge": "^5.0.3",
    "@types/node": "^24.0.0",
    "@yao-pkg/pkg": "^6.14.1",
    "c8": "^11.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cross-spawn": "^7.0.6",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  }
}
