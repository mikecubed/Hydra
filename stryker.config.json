{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "command",
  "testRunnerNodeArgs": ["--experimental-test-module-mocks"],
  "commandRunner": {
    "command": "node --test --experimental-test-module-mocks 'test/**/*.test.{ts,mjs}'"
  },
  "coverageAnalysis": "off",
  "mutate": ["lib/hydra-shared/**/*.ts", "!lib/hydra-shared/**/*.test.ts"],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "thresholds": {
    "high": 60,
    "low": 40,
    "break": null
  },
  "timeoutMS": 60000,
  "concurrency": 2
}
