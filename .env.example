# ── Hydra API Keys ──────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Real environment variables always take priority over .env values.

# Required for Codex agent, Concierge, and Investigator
OPENAI_API_KEY=

# Optional — only used by :model:select for listing available models
# (Claude uses CLI subscription auth, Gemini uses CLI/OAuth — no API key needed)
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ── Gemini Direct API (OAuth token refresh) ─────────────
# Required when using the Gemini Direct API fallback (bypass for broken CLI versions).
# The client secret MUST be provided here — it must never be hardcoded in source.
# Obtain these values from the Google Cloud Console for your installed-app OAuth client,
# or reuse the Gemini CLI's registered credentials.
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=

# ── Daemon Networking ───────────────────────────────────
# AI_ORCH_HOST=127.0.0.1
# AI_ORCH_PORT=4173
# AI_ORCH_TOKEN=

# ── Per-Agent Model Overrides ───────────────────────────
# These override all config-file settings for the agent.
# HYDRA_CLAUDE_MODEL=claude-sonnet-4-5-20250929
# HYDRA_GEMINI_MODEL=gemini-2.5-flash
# HYDRA_CODEX_MODEL=o4-mini
