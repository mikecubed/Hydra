# ── Hydra API Keys ──────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Real environment variables always take priority over .env values.

# Required for Codex agent, Concierge, and Investigator
OPENAI_API_KEY=

# Optional — only used by :model:select for listing available models
# (Claude uses CLI subscription auth, Gemini uses CLI/OAuth — no API key needed)
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ── Daemon Networking ───────────────────────────────────
# AI_ORCH_HOST=127.0.0.1
# AI_ORCH_PORT=4173
# AI_ORCH_TOKEN=

# ── Per-Agent Model Overrides ───────────────────────────
# These override all config-file settings for the agent.
# HYDRA_CLAUDE_MODEL=claude-sonnet-4-5-20250929
# HYDRA_GEMINI_MODEL=gemini-2.5-flash
# HYDRA_CODEX_MODEL=o4-mini
