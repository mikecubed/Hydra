    "phases": {
      "researchTimeoutMs": 300000,
      "deliberateTimeoutMs": 420000,
      "planTimeoutMs": 300000,
      "testTimeoutMs": 600000,
      "implementTimeoutMs": 900000,
      "analyzeTimeoutMs": 420000
    },
    "approval": {
      "minScore": 7,
      "requireAllTestsPass": true,
      "requireNoViolations": true
    },
    "baseBranch": "dev",
    "investigator": {
      "enabled": true,
      "model": "gpt-5.3",
      "reasoningEffort": "high",
      "maxAttemptsPerPhase": 2,
      "phases": [
        "test",
        "implement",
        "analyze",
        "agent"
      ],
      "maxTokensBudget": 50000,
      "tryAlternativeAgent": true,
      "logToFile": true
    }
  },
  "github": {
    "enabled": false,
    "defaultBase": "",
    "draft": false,
    "labels": [],
    "reviewers": [],
    "prBodyFooter": ""
