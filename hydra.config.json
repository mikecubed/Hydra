        "security-reviewer",
        "test-writer",
        "doc-generator",
        "researcher",
        "evolve-researcher"
      ]
    },
    "custom": {}
  },
  "evolve": {
    "maxRounds": 3,
    "maxHours": 4,
    "focusAreas": [
      "orchestration-patterns",
      "ai-coding-tools",
      "testing-reliability",
      "developer-experience",
      "model-routing",
      "daemon-architecture"
    ],
    "budget": {
      "softLimit": 600000,
      "hardLimit": 800000,
      "perRoundEstimate": 200000,
      "warnThreshold": 0.6,
      "reduceScopeThreshold": 0.75,
      "softStopThreshold": 0.85,
      "hardStopThreshold": 0.95
